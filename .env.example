# ============================================
# 伴聊悬浮舱 (Context-Pod) 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ============================================

# DeepSeek API 配置
VITE_DEEPSEEK_API_KEY=sk-your-api-key-here
VITE_DEEPSEEK_BASE_URL=https://api.deepseek.com

# LLM 模型选择
VITE_LLM_MODEL=deepseek-chat

# 本地 Embedding 模型
VITE_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
