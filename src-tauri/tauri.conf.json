{
    "$schema": "https://raw.githubusercontent.com/nicehash/Tauri/dev/crates/tauri-config-schema/schema.json",
    "productName": "дјґиЃЉж‚¬жµ®и€±",
    "version": "0.1.0",
    "identifier": "com.context-pod.app",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "дјґиЃЉж‚¬жµ®и€±",
                "label": "main",
                "width": 400,
                "height": 580,
                "minWidth": 340,
                "minHeight": 400,
                "decorations": false,
                "transparent": true,
                "alwaysOnTop": true,
                "skipTaskbar": true,
                "resizable": false,
                "visible": true,
                "center": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": ["nsis"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.png",
            "icons/icon.ico"
        ],
        "iOS": {
            "minimumSystemVersion": "13.0"
        },
        "android": {
            "minSdkVersion": 24
        }
    },
    "plugins": {
        "global-shortcut": null,
        "clipboard-manager": null
    }
}